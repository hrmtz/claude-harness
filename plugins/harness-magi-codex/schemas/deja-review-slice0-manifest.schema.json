{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deja Review Slice 0 corpus manifest",
  "type": "object",
  "properties": {
    "schema_version": {"const": "deja-review-slice0-campaign/v1"},
    "campaign_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
    },
    "immutable_input_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "normalizer_implementation_sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifact_count": {"type": "integer", "minimum": 1, "maximum": 256},
    "finding_count": {"type": "integer", "minimum": 0, "maximum": 262144},
    "normalized_bytes": {"type": "integer", "minimum": 0},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "required": [
    "schema_version",
    "campaign_id",
    "immutable_input_digest",
    "normalizer_implementation_sha",
    "artifact_count",
    "finding_count",
    "normalized_bytes",
    "created_at"
  ],
  "additionalProperties": false
}
