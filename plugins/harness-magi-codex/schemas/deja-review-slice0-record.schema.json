{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deja Review Slice 0 normalized finding",
  "type": "object",
  "properties": {
    "schema_version": {"const": "deja-review-slice0-record/v1"},
    "normalizer_version": {"const": "deja-review-slice0-normalizer/v1"},
    "occurrence_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_path": {"type": "string", "minLength": 1},
    "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_artifact_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
    "reviewed_artifact_sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "reviewer": {"type": "string", "minLength": 1},
    "round": {"type": "integer", "minimum": 1},
    "verdict": {"type": "string", "enum": ["GO", "GO-WITH-REVISE", "REVISE", "REJECT"]},
    "schema_grounding_verdict": {"type": "string", "enum": ["PASS", "PARTIAL", "FAIL"]},
    "finding_id": {"type": "string", "minLength": 1},
    "severity": {"type": "string", "enum": ["REJECT", "CRITICAL", "HIGH", "MED", "LOW", "nit"]},
    "title": {"type": "string"},
    "location": {"type": "string"},
    "rationale": {"type": "string"},
    "required_fix": {"type": "string"},
    "confidence": {"type": "string", "enum": ["high", "med", "low"]},
    "dup_flag": {"type": "string", "enum": ["new", "duplicate", "regression", "readiness-gap", "scope-expansion"]},
    "missed_angle": {"type": "string"},
    "subsystem": {"type": "string", "minLength": 1},
    "root_cause_id": {"type": "string", "minLength": 1},
    "affected_invariant": {"type": "string", "minLength": 1},
    "changes_design_invariant": {"type": "boolean"},
    "relation_to_prior": {
      "type": "string",
      "enum": ["new-root", "same-root", "fix-induced-regression", "none"]
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "correctness",
          "rollback",
          "security",
          "data-integrity",
          "performance",
          "operability",
          "maintainability",
          "api-design",
          "testing",
          "cost",
          "privacy",
          "other"
        ]
      }
    },
    "category_derivation": {"const": "magi-category-v1"},
    "trust": {"const": "untrusted-review-content"}
  },
  "required": [
    "schema_version",
    "normalizer_version",
    "occurrence_id",
    "source_path",
    "source_sha256",
    "source_artifact_id",
    "reviewed_artifact_sha",
    "reviewer",
    "round",
    "verdict",
    "schema_grounding_verdict",
    "finding_id",
    "severity",
    "title",
    "location",
    "rationale",
    "required_fix",
    "confidence",
    "dup_flag",
    "missed_angle",
    "categories",
    "category_derivation",
    "trust"
  ],
  "additionalProperties": false
}
