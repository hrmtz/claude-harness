{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "const": "magi-preflight-review/v1"
    },
    "reviewer": {
      "type": "string",
      "enum": ["MELCHIOR", "BALTHASAR", "CASPAR"]
    },
    "round": {
      "const": 1
    },
    "brief": {
      "type": "object",
      "properties": {
        "canonical_path": {
          "type": "string",
          "minLength": 1
        },
        "artifact_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{16}$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "required": ["canonical_path", "artifact_id", "sha256"],
      "additionalProperties": false
    },
    "verdict": {
      "type": "string",
      "enum": ["PROCEED", "PIVOT", "ABORT"]
    },
    "findings": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
          },
          "root_cause_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$"
          },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MED", "LOW"]
          },
          "impact": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "technical",
                "operational",
                "commercial",
                "security",
                "data-loss",
                "irreversibility"
              ]
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "rationale": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8000
          },
          "required_change": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          },
          "recommended_decision": {
            "type": "string",
            "enum": ["PIVOT", "ABORT"]
          },
          "evidence": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "brief-lines"
                },
                "start_line": {
                  "type": "integer",
                  "minimum": 1
                },
                "end_line": {
                  "type": "integer",
                  "minimum": 1
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                }
              },
              "required": ["kind", "start_line", "end_line", "sha256"],
              "additionalProperties": false
            }
          },
          "question_if_uncorroborated": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          }
        },
        "required": [
          "finding_id",
          "root_cause_id",
          "severity",
          "impact",
          "summary",
          "rationale",
          "required_change",
          "recommended_decision",
          "evidence",
          "question_if_uncorroborated"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["schema", "reviewer", "round", "brief", "verdict", "findings"],
  "additionalProperties": false
}
