#!/bin/bash
# Publish cache-independent Codex hook and launcher entrypoints.

set -euo pipefail

[[ -n "${CODEX_THREAD_ID:-}" || "${1:-}" == "--replace" ]] || exit 0
replace=0
[[ "${1:-}" == "--replace" ]] && replace=1
[[ $# -le 1 ]] || {
  echo "usage: install-cache-safe-entrypoints [--replace]" >&2
  exit 64
}

command -v codex >/dev/null 2>&1 || {
  echo "cache-safe bootstrap: codex is not installed" >&2
  exit 1
}
command -v jq >/dev/null 2>&1 || {
  echo "cache-safe bootstrap: jq is required" >&2
  exit 1
}

codex_command="$(command -v codex)"
codex_real="$(readlink -f "$codex_command")"
standalone_current="$HOME/.codex/packages/standalone/current/bin/codex"
if [[ "$(basename "$codex_real")" == "codex-cache-safe" ]]; then
  if [[ -x "$HOME/.local/libexec/claude-harness-codex-real" ]]; then
    codex_real="$HOME/.local/libexec/claude-harness-codex-real"
  else
    codex_real="$standalone_current"
  fi
fi
[[ -x "$codex_real" ]] || {
  echo "cache-safe bootstrap: real Codex binary is unavailable" >&2
  exit 1
}

inventory="$("$codex_real" plugin list --json 2>/dev/null)" || {
  echo "cache-safe bootstrap: could not read plugin inventory" >&2
  exit 1
}
core_source="$(jq -er '
  first(
    .installed[]
    | select(
        .pluginId == "harness-core@claude-harness" and
        .installed == true and
        .enabled == true and
        (.source.path | type) == "string"
      )
    | .source.path
  )
' <<<"$inventory")" || {
  echo "cache-safe bootstrap: live harness-core source is unavailable" >&2
  exit 1
}
core_source="$(realpath "$core_source")"
[[ -x "$core_source/bin/harness-hook" &&
   -x "$core_source/bin/codex-cache-safe" &&
   "$(jq -r '.name // ""' "$core_source/.codex-plugin/plugin.json")" == "harness-core" ]] || {
  echo "cache-safe bootstrap: invalid harness-core source: $core_source" >&2
  exit 1
}

codex_state_home="${CODEX_HOME:-$HOME/.codex}"
inventory_snapshot="$codex_state_home/plugins/harness-local-inventory.json"
mkdir -p "$(dirname "$inventory_snapshot")"
inventory_stage="$(mktemp "$(dirname "$inventory_snapshot")/.harness-inventory.XXXXXX")"
if ! jq -e '
  [
    .installed[]
    | select(
        .installed == true and
        .enabled == true and
        (.marketplaceSource.sourceType // "unknown") == "local" and
        .marketplaceName != "openai-curated" and
        .marketplaceName != "openai-curated-remote"
      )
    | {
        plugin_id: .pluginId,
        marketplace: .marketplaceName,
        plugin_name: .name,
        source_path: .source.path
      }
  ]
  | if all(.[]; all(.[]; type == "string"))
    then .
    else error("invalid inventory snapshot row")
    end
' <<<"$inventory" >"$inventory_stage"; then
  rm -f "$inventory_stage"
  echo "cache-safe bootstrap: malformed plugin inventory" >&2
  exit 1
fi
mv -f "$inventory_stage" "$inventory_snapshot"

backup_root=""
if [[ "$replace" == "1" ]]; then
  backup_root="$HOME/sanada_backup_persistent/codex_cache_safe_$(date +%Y%m%d_%H%M%S)"
  mkdir -p "$backup_root"
fi

stable_link() {
  local target="$1" link="$2" backup_name="$3"
  mkdir -p "$(dirname "$link")"
  if [[ -e "$link" || -L "$link" ]]; then
    if [[ "$(readlink -f "$link" 2>/dev/null || true)" == "$(readlink -f "$target")" ]]; then
      return 0
    fi
    if [[ "$replace" != "1" ]]; then
      echo "cache-safe bootstrap: preserving conflicting path: $link" >&2
      return 2
    fi
    mv "$link" "$backup_root/$backup_name"
  fi
  ln -s "$target" "$link"
}

real_link="$HOME/.local/libexec/claude-harness-codex-real"
if [[ ! -x "$real_link" ]]; then
  real_command="$codex_command"
  real_candidate="$codex_real"
  if [[ "$(basename "$real_candidate")" == "codex-cache-safe" ]]; then
    real_candidate="$standalone_current"
  elif [[ -x "$standalone_current" &&
          "$real_candidate" == "$(readlink -f "$standalone_current")" ]]; then
    real_candidate="$standalone_current"
  fi
  [[ -x "$real_candidate" ]] || {
    echo "cache-safe bootstrap: real Codex binary is unavailable" >&2
    exit 1
  }
  if [[ "$replace" == "1" &&
        "$real_command" == "$HOME/.local/bin/codex" &&
        ! -L "$real_command" ]]; then
    mkdir -p "$(dirname "$real_link")"
    cp -a "$real_command" "$backup_root/codex.previous"
    mv "$real_command" "$real_link"
    real_candidate="$real_link"
  fi
  stable_link "$real_candidate" "$real_link" codex-real.previous
fi

stable_link "$core_source/bin/harness-hook" \
  "$HOME/.local/bin/harness-hook" harness-hook.previous
stable_link "$core_source/bin/codex-cache-safe" \
  "$HOME/.local/bin/codex-cache-safe" codex-cache-safe.previous

if [[ ! -e "$HOME/.local/bin/codex" && ! -L "$HOME/.local/bin/codex" ]]; then
  stable_link "$core_source/bin/codex-cache-safe" \
    "$HOME/.local/bin/codex" codex.previous
elif [[ "$replace" == "1" ]]; then
  stable_link "$core_source/bin/codex-cache-safe" \
    "$HOME/.local/bin/codex" codex.previous
fi
