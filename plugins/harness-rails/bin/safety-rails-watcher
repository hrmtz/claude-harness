#!/bin/bash
# safety-rails watcher entry point — invoke from cron
# */1 * * * * /path/to/safety-rails-watcher >> /var/log/safety-rails-watcher.log 2>&1
set -euo pipefail
PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec python3 -c "
import sys
sys.path.insert(0, '${PLUGIN_DIR}/lib')
from safety_rails.watcher import main
sys.exit(main())
" "$@"
